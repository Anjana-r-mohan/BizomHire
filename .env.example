# Environment Variables Configuration

# Session secret key (change this in production!)
SESSION_SECRET=your-secure-random-secret-key-here

# Environment (development or production)
NODE_ENV=development

# Database configuration
USE_FIRESTORE=false

# Allowed email addresses for authentication (comma-separated)
# Add all authorized email addresses here
ALLOWED_EMAILS=user1@example.com,user2@example.com,admin@company.com

# Google Cloud Project (for Firestore in production)
GOOGLE_CLOUD_PROJECT=your-project-id
